@extern(main)
func main()u8{
    let i = 10
    if i == 1{
        i = 1
    }else if i == 2{
        i = 2
    }else{
        if i == 3{
            i = 3
        }
        i = 12
    }
    for i > 0{
        if i > 5{
            i -= 2
        }else{
            i -= 1
        }
    }
    switch i{
    case 0:
        i = 0
    case 2:
        i = 11
    default:
        i = 1
    }
    return i as u8
}