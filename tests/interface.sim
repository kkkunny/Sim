@extern(printf)
func printf(*i8, i32)

type A interface{
    get: func()i32
}

type B interface{
    set: func(i32)
}

func (B) set2(v: i32){
    self.set(v)
}

type C(A, B) struct{
    value: i32
}

func (C) get()i32{
    return self.value
}

func (C) set(v: i32){
    self.value = v
}

@extern(main)
func main()u8{
    let c: C = {10}
    let b: B = &c
    b.set2(2)
    let a: A = &c
    printf("%d\n", a.get())
    return 0
}